# ============================================================
# Adaptive Multimodal Educational RAG Assistant
# Environment Variables — Copy to .env and fill in your values
# ============================================================

# --- GROQ API ---
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# --- NEON POSTGRESQL ---
# Get from: https://console.neon.tech → Your Project → Connection String
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=your_neon_connection_string_here

# --- LLM SETTINGS ---
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=4096

# --- EMBEDDING MODEL ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- RETRIEVAL SETTINGS ---
TOP_K_RESULTS=8
SIMILARITY_THRESHOLD=0.35
BM25_WEIGHT=0.3
SEMANTIC_WEIGHT=0.7
MAX_CONTEXT_TOKENS=6000
RERANK_TOP_N=5

# --- CHUNKING SETTINGS ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- APP SETTINGS ---
APP_TITLE=EduRAG Assistant
DEBUG_MODE=false
LOG_LEVEL=INFO

# --- WHISPER (for audio/video transcription) ---
# Options: groq (uses Groq Whisper API) | local (openai-whisper package)
WHISPER_MODE=groq
# Local whisper model size (tiny/base/small/medium/large) — only if WHISPER_MODE=local
WHISPER_LOCAL_MODEL=base
